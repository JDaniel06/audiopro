# Copia este archivo como .env y ajusta los valores

# Django
SECRET_KEY=django-insecure-cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=*

# Base de datos (SQLite por defecto en práctica, no se necesita configurar)
# Para PostgreSQL en producción, descomenta y configura:
# DB_NAME=audiostoredb
# DB_USER=audiouser
# DB_PASSWORD=audiopass
# DB_HOST=localhost
# DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
